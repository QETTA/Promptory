# ─────────────────────────────────────────────────────────────
# Promptory 환경 변수 설정 예시
# .env.local 에 복사 후 실제 값으로 교체하세요
# ─────────────────────────────────────────────────────────────

# 앱 기본 URL (로컬: http://localhost:3000)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase 프로젝트 설정
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# 결제 설정 (dev_stub | production)
PAYMENTS_MODE=dev_stub
NEXT_PUBLIC_TOSS_CLIENT_KEY=
TOSS_SECRET_KEY=

# ─────────────────────────────────────────────────────────────
# Cloudflare Access 설정
# 배포 환경에서 CF Access JWT 검증에 사용됩니다.
#
# 공개 키 URL: https://<TEAM_DOMAIN>/cdn-cgi/access/certs
# 예: https://lider-yohan.cloudflareaccess.com/cdn-cgi/access/certs
#
# AUD는 CF Access Application 생성 시 발급되는 Client ID입니다.
# ─────────────────────────────────────────────────────────────
CF_ACCESS_TEAM_DOMAIN=lider-yohan.cloudflareaccess.com
CF_ACCESS_AUD=

# ─────────────────────────────────────────────────────────────
# Cloudflare 배포 설정 (GitHub Actions CI/CD)
# GitHub Repository Secrets에 등록하세요:
#   - CLOUDFLARE_API_TOKEN: CF API Token (Edit Pages 권한)
#   - CLOUDFLARE_ACCOUNT_ID: CF Account ID
# ─────────────────────────────────────────────────────────────
# CLOUDFLARE_API_TOKEN=  # GitHub Secret으로 관리
# CLOUDFLARE_ACCOUNT_ID= # GitHub Secret으로 관리
